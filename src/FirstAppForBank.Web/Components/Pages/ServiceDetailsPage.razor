@page "/services/{Id:guid}"
@layout MainLayout
@inject IServiceCatalogReader ServiceCatalogReader
@inject NavigationManager NavigationManager

<PageTitle>Карточка сервиса</PageTitle>

@if (_service is null)
{
    <p>Сервис не найден.</p>
    <button class="back-button" @onclick="GoBack">Вернуться к каталогу</button>
}
else
{
    <div class="details-header">
        <div>
            <p class="breadcrumbs"><a href="/services">Каталог</a> / @_service.Category</p>
            <h1>@_service.Name</h1>
            <p class="page-description">@_service.Description</p>
        </div>
        <span class="status-chip status-@_service.Status.ToLowerInvariant()">@_service.Status</span>
    </div>

    <section class="details-grid">
        <article class="details-card">
            <h2>Общая информация</h2>
            <dl>
                <dt>Категория</dt>
                <dd>@_service.Category</dd>

                <dt>Критичность</dt>
                <dd>@_service.Criticality</dd>

                <dt>Тип</dt>
                <dd>@_service.ServiceType</dd>

                <dt>Владелец</dt>
                <dd>@_service.Owner</dd>

                <dt>Последнее изменение статуса</dt>
                <dd>@_service.LastStatusChangedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
            </dl>
        </article>

        <article class="details-card">
            <h2>Ссылки и материалы</h2>
            <ul class="links-list">
                <li><a href="@_service.RunbookUrl" target="_blank">Runbook</a></li>
                <li><a href="@_service.DashboardUrl" target="_blank">Dashboard</a></li>
            </ul>
            <p class="notes-block">@_service.Notes</p>
        </article>
    </section>

    <section class="details-card">
        <h2>История статусов</h2>
        @if (_service.StatusHistory.Count == 0)
        {
            <p>История статусов пока отсутствует.</p>
        }
        else
        {
            <div class="timeline-list">
                @foreach (var item in _service.StatusHistory)
                {
                    <div class="timeline-item">
                        <div class="timeline-meta">
                            <strong>@item.ChangedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</strong>
                            <span>@item.ChangeSourceType</span>
                        </div>
                        <div class="timeline-content">
                            <div>
                                <span class="status-chip status-@((item.OldStatus ?? "unknown").ToLowerInvariant())">@(item.OldStatus ?? "N/A")</span>
                                <span class="timeline-arrow">→</span>
                                <span class="status-chip status-@item.NewStatus.ToLowerInvariant()">@item.NewStatus</span>
                            </div>
                            <p>@item.Comment</p>
                            <small>Источник: @item.ChangeSource</small>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <section class="details-card">
        <h2>Комментарии</h2>
        @if (_service.Comments.Count == 0)
        {
            <p>Комментариев пока нет.</p>
        }
        else
        {
            <div class="comment-list">
                @foreach (var comment in _service.Comments)
                {
                    <div class="comment-item">
                        <div class="comment-header">
                            <strong>@comment.AuthorName</strong>
                            <span>@comment.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <p>@comment.CommentText</p>
                    </div>
                }
            </div>
        }
    </section>

    <button class="back-button" @onclick="GoBack">Вернуться к каталогу</button>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private ServiceDetailsDto? _service;

    protected override async Task OnParametersSetAsync()
    {
        _service = await ServiceCatalogReader.GetServiceByIdAsync(Id);
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/services");
    }
}
