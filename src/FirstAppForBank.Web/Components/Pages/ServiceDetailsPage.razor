@page "/services/{Id:guid}"
@layout MainLayout
@inject IServiceCatalogReader ServiceCatalogReader
@inject IMetricHistoryReader MetricHistoryReader
@inject NavigationManager NavigationManager

<PageTitle>Карточка сервиса</PageTitle>

@if (_service is null)
{
    <p>Сервис не найден.</p>
    <button class="back-button" @onclick="GoBack">Вернуться к каталогу</button>
}
else
{
    <div class="details-header">
        <div>
            <p class="breadcrumbs"><a href="/services">Каталог</a> / @_service.Category</p>
            <h1>@_service.Name</h1>
            <p class="page-description">@_service.Description</p>
        </div>
        <span class="status-chip status-@_service.Status.ToLowerInvariant()">@_service.Status</span>
    </div>

    <section class="details-grid">
        <article class="details-card">
            <h2>Общая информация</h2>
            <dl>
                <dt>Категория</dt>
                <dd>@_service.Category</dd>
                <dt>Критичность</dt>
                <dd>@_service.Criticality</dd>
                <dt>Тип</dt>
                <dd>@_service.ServiceType</dd>
                <dt>Владелец</dt>
                <dd>@_service.Owner</dd>
                <dt>Последнее изменение статуса</dt>
                <dd>@_service.LastStatusChangedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
            </dl>
        </article>

        <article class="details-card">
            <h2>Ссылки и материалы</h2>
            <ul class="links-list">
                <li><a href="@_service.RunbookUrl" target="_blank">Runbook</a></li>
                <li><a href="@_service.DashboardUrl" target="_blank">Dashboard</a></li>
            </ul>
            <p class="notes-block">@_service.Notes</p>
        </article>
    </section>

    <section class="details-card">
        <div class="metrics-header">
            <h2>Metrics / Dynamics</h2>
            <div class="range-switcher">
                <button class="@RangeButtonClass(MetricsRange.Last24Hours)" @onclick="() => ChangeRangeAsync(MetricsRange.Last24Hours)">24ч</button>
                <button class="@RangeButtonClass(MetricsRange.Last7Days)" @onclick="() => ChangeRangeAsync(MetricsRange.Last7Days)">7д</button>
                <button class="@RangeButtonClass(MetricsRange.Last30Days)" @onclick="() => ChangeRangeAsync(MetricsRange.Last30Days)">30д</button>
            </div>
        </div>

        @if (_metrics is null)
        {
            <p>Загрузка метрик...</p>
        }
        else
        {
            <div class="metric-series-grid">
                @foreach (var series in _metrics.Series)
                {
                    <article class="metric-series-card">
                        <div class="metric-series-title-row">
                            <h3>@series.DisplayName</h3>
                            <span>@series.Unit</span>
                        </div>

                        @if (series.Points.Count == 0)
                        {
                            <p>Нет данных за выбранный интервал.</p>
                        }
                        else
                        {
                            <div class="metric-summary-row">
                                <div>
                                    <span class="metric-summary-label">Текущее</span>
                                    <strong>@FormatMetricValue(series.Points.Last().Value, series.Unit)</strong>
                                </div>
                                <div>
                                    <span class="metric-summary-label">Min</span>
                                    <strong>@FormatMetricValue(series.Points.Min(x => x.Value), series.Unit)</strong>
                                </div>
                                <div>
                                    <span class="metric-summary-label">Max</span>
                                    <strong>@FormatMetricValue(series.Points.Max(x => x.Value), series.Unit)</strong>
                                </div>
                            </div>

                            <div class="mini-chart">
                                @foreach (var point in series.Points)
                                {
                                    <div class="mini-bar-wrapper">
                                        <div class="mini-bar" style="height:@GetBarHeight(point.Value, series.Points)%"></div>
                                    </div>
                                }
                            </div>

                            <div class="metric-footnote">
                                Последняя точка: @series.Points.Last().Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </div>
                        }
                    </article>
                }
            </div>
        }
    </section>

    <section class="details-card">
        <h2>История статусов</h2>
        @if (_service.StatusHistory.Count == 0)
        {
            <p>История статусов пока отсутствует.</p>
        }
        else
        {
            <div class="timeline-list">
                @foreach (var item in _service.StatusHistory)
                {
                    <div class="timeline-item">
                        <div class="timeline-meta">
                            <strong>@item.ChangedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</strong>
                            <span>@item.ChangeSourceType</span>
                        </div>
                        <div class="timeline-content">
                            <div>
                                <span class="status-chip status-@((item.OldStatus ?? "unknown").ToLowerInvariant())">@(item.OldStatus ?? "N/A")</span>
                                <span class="timeline-arrow">→</span>
                                <span class="status-chip status-@item.NewStatus.ToLowerInvariant()">@item.NewStatus</span>
                            </div>
                            <p>@item.Comment</p>
                            <small>Источник: @item.ChangeSource</small>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <section class="details-card">
        <h2>Комментарии</h2>
        @if (_service.Comments.Count == 0)
        {
            <p>Комментариев пока нет.</p>
        }
        else
        {
            <div class="comment-list">
                @foreach (var comment in _service.Comments)
                {
                    <div class="comment-item">
                        <div class="comment-header">
                            <strong>@comment.AuthorName</strong>
                            <span>@comment.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <p>@comment.CommentText</p>
                    </div>
                }
            </div>
        }
    </section>

    <button class="back-button" @onclick="GoBack">Вернуться к каталогу</button>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private ServiceDetailsDto? _service;
    private ServiceMetricsDto? _metrics;
    private MetricsRange _selectedRange = MetricsRange.Last24Hours;

    protected override async Task OnParametersSetAsync()
    {
        _service = await ServiceCatalogReader.GetServiceByIdAsync(Id);

        if (_service is not null)
        {
            _metrics = await MetricHistoryReader.GetMetricsAsync(_service.Name, _selectedRange);
        }
    }

    private async Task ChangeRangeAsync(MetricsRange range)
    {
        if (_service is null)
        {
            return;
        }

        _selectedRange = range;
        _metrics = await MetricHistoryReader.GetMetricsAsync(_service.Name, _selectedRange);
    }

    private string RangeButtonClass(MetricsRange range)
    {
        return _selectedRange == range ? "range-button active" : "range-button";
    }

    private static string FormatMetricValue(double value, string unit)
    {
        return unit switch
        {
            "%" => $"{value:F2}%",
            _ => $"{value:F2} {unit}"
        };
    }

    private static double GetBarHeight(double value, IReadOnlyCollection<MetricPointDto> points)
    {
        var max = points.Max(x => x.Value);
        if (max <= 0)
        {
            return 5;
        }

        var height = value / max * 100;
        return Math.Max(8, Math.Round(height, 2));
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/services");
    }
}
