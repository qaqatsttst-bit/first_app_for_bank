@page "/categories"
@layout MainLayout
@inject IAdministrationCatalogService AdminService

<PageTitle>Categories</PageTitle>

<h1>Управление категориями</h1>
<p class="page-description">Базовый административный раздел для создания и изменения категорий сервисов.</p>

<section class="admin-grid">
    <article class="details-card admin-form-card">
        <h2>@(_editingId is null ? "Новая категория" : "Редактирование категории")</h2>

        <div class="form-field">
            <label>Название</label>
            <input @bind="_name" />
        </div>

        <div class="form-field">
            <label>Описание</label>
            <textarea rows="4" @bind="_description"></textarea>
        </div>

        <label class="checkbox-field">
            <input type="checkbox" @bind="_isActive" />
            <span>Активна</span>
        </label>

        <div class="form-actions">
            <button class="primary-button" @onclick="SaveAsync">@(_editingId is null ? "Создать" : "Сохранить")</button>
            @if (_editingId is not null)
            {
                <button class="secondary-button" @onclick="ResetForm">Отмена</button>
            }
        </div>
    </article>

    <article class="details-card">
        <h2>Список категорий</h2>

        @if (_categories is null)
        {
            <p>Загрузка...</p>
        }
        else
        {
            <div class="admin-list">
                @foreach (var category in _categories)
                {
                    <div class="admin-list-item">
                        <div>
                            <strong>@category.Name</strong>
                            <div class="admin-list-meta">@(category.IsActive ? "Active" : "Inactive")</div>
                            <div class="admin-list-text">@category.Description</div>
                        </div>
                        <button class="secondary-button" @onclick="() => StartEdit(category)">Редактировать</button>
                    </div>
                }
            </div>
        }
    </article>
</section>

@code {
    private IReadOnlyCollection<CategoryAdminDto>? _categories;
    private Guid? _editingId;
    private string _name = string.Empty;
    private string? _description;
    private bool _isActive = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _categories = await AdminService.GetCategoriesAsync();
    }

    private async Task SaveAsync()
    {
        var request = new UpsertCategoryRequest
        {
            Name = _name,
            Description = _description,
            IsActive = _isActive
        };

        if (_editingId is null)
        {
            await AdminService.CreateCategoryAsync(request);
        }
        else
        {
            await AdminService.UpdateCategoryAsync(_editingId.Value, request);
        }

        ResetForm();
        await LoadAsync();
    }

    private void StartEdit(CategoryAdminDto category)
    {
        _editingId = category.Id;
        _name = category.Name;
        _description = category.Description;
        _isActive = category.IsActive;
    }

    private void ResetForm()
    {
        _editingId = null;
        _name = string.Empty;
        _description = string.Empty;
        _isActive = true;
    }
}
